# Base URL for MVV EFA API
MVV_API_BASE_URL=<YOUR_MVV_API_BASE_URL>

# Paths for various MVV EFA API endpoints
MVV_API_STOP_FINDER_PATH=<YOUR_MVV_API_STOP_FINDER_PATH>
MVV_API_STOP_FINDER_PATH_COORD=<YOUR_MVV_API_STOP_FINDER_PATH_COORD>
MVV_API_COORDS_PATH=<YOUR_MVV_API_COORDS_PATH>
MVV_API_COORDS_PATH_QUICK=<YOUR_MVV_API_COORDS_PATH_QUICK>
MVV_API_ROUTE_PATH=<YOUR_MVV_API_ROUTE_PATH>

# OpenTripPlanner setup
OTP_BASE_URL=http://otp:8080  # use http://otp:8080 when running via docker-compose, otherwise your local OTP URL
OTP_ROUTE_PATH=otp/routers/default/plan
OTP_ENDPOINT_PATH=<YOUR_OTP_ENDPOINT_PATH>  # Select random, this creates a separate OTP Endpoint of your flask app

# OpenTripPlanner Docker settings
JAVA_TOOL_OPTIONS=-Xmx8g  # memory allocated to OTP, adjust based on your server

# Application setup
APP_BASE_URL=<YOUR_APP_BASE_ROUTE> # important in production and for CORS
APP_BACKEND_PATH=platform


